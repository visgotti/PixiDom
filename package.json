{
  "name": "pixidom.js",
  "version": "1.0.0",
  "description": "A lightweight UI component library for PixiJS - text inputs, buttons, toggles, sliders, and scrollable lists",
  "keywords": [
    "pixi",
    "pixijs",
    "ui",
    "components",
    "textfield",
    "button",
    "toggle",
    "slider",
    "scrolllist",
    "canvas",
    "webgl",
    "game",
    "interactive"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild-types.js",
    "build:demo": "npm run build && node scripts/build-gh-pages.js",
    "dev:demo": "npm run build && npx serve",
    "watch:lib": "vite build --watch",
    "preview": "vite preview",
    "test": "mocha --recursive --require ts-node/register 'test/**/*.test.ts' --exit",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:update": "npm run build && playwright test --update-snapshots",
    "test:all": "npm run test && npm run test:e2e",
    "test:smoke": "node scripts/smoke-import.mjs",
    "serve:examples": "node scripts/serve-examples.js",
    "e2e": "npm run test:e2e",
    "e2e:report": "sh -c 'npm run test:e2e; STATUS=$?; npx playwright show-report; exit $STATUS'",
    "snapshot-report": "sh -c 'npm run test:e2e; node scripts/generate-snapshot-report.js'",
    "snapshot-report:readme": "node scripts/generate-snapshot-report.js && node scripts/inject-snapshot-readme.js",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test && npm run test:smoke"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.mjs",
    "dist/**/*.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "dist/**/*.d.cts",
    "!dist/pixi-bootstrap.d.ts",
    "!dist/**/*.d.ts.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "peerDependencies": {
    "pixi.js": ">=4.0.0"
  },
  "type": "commonjs",
  "sideEffects": [
    "./dist/index.cjs",
    "./dist/index.es.mjs",
    "./dist/pixidom.js"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.es.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/pixidom.js",
  "jsdelivr": "dist/pixidom.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.es.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "visgotti",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/chai": "^4.1.7",
    "@types/mocha": "^5.2.6",
    "@types/tween-functions": "^1.2.2",
    "chai": "^4.2.0",
    "tween-functions": "^1.2.0",
    "mocha": "^6.1.4",
    "pixi.js": "^8.1.5",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visgotti/PixiDom.git"
  },
  "bugs": {
    "url": "https://github.com/visgotti/PixiDom/issues"
  },
  "homepage": "https://github.com/visgotti/PixiDom#readme"
}
